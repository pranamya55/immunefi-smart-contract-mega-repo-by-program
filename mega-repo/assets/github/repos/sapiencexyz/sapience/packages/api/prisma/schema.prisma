generator client {
  provider      = "prisma-client-js"
  output        = "../generated/prisma"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

generator typegraphql {
  provider = "typegraphql-prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id           Int            @id(map: "PK_9c4e4a89e3674fc9f382d733f03") @default(autoincrement())
  createdAt    DateTime       @default(now()) @db.Timestamp(6)
  name         String         @db.VarChar
  slug         String         @unique(map: "UQ_cb73208f151aa71cdd78f662d70") @db.VarChar
  /// @TypeGraphQL.field(name: "conditions")
  condition       Condition[]
  /// @TypeGraphQL.field(name: "conditionGroups")
  condition_group ConditionGroup[]

  @@index([slug], map: "IDX_cb73208f151aa71cdd78f662d7")
  @@map("category")
}

model Event {
  id              Int           @id(map: "PK_30c2f3bbaf6d34a55f8ae6e4614") @default(autoincrement())
  createdAt       DateTime      @default(now()) @db.Timestamp(6)
  blockNumber     Int
  transactionHash String        @db.VarChar
  timestamp       BigInt
  logIndex        Int
  logData         Json          @db.Json

  @@index([timestamp], map: "IDX_2c15918ff289396205521c5f3c")
  @@index([blockNumber], map: "IDX_5430e2d7fe1df2bcada2c12deb")
  @@map("event")
}

model KeyValueStore {
  key       String   @id @db.VarChar(255)
  value     String   @db.Text
  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @updatedAt @db.Timestamp(6)

  @@map("key_value_store")
}

model Migrations {
  id        Int    @id(map: "PK_8c82d7f526340ab734260ea46be") @default(autoincrement())
  timestamp BigInt
  name      String @db.VarChar

  @@map("migrations")
}

model BackgroundJob {
  id        Int      @id(map: "PK_a00488019eafb11b27af1aa1a76") @default(autoincrement())
  createdAt DateTime @default(now()) @db.Timestamp(6)
  command   String   @db.VarChar
  status    String   @db.VarChar
  params    String?  @db.VarChar

  @@map("background_job")
}

model Attestation {
  id              Int      @id(map: "PK_attestation") @default(autoincrement())
  createdAt       DateTime @default(now()) @db.Timestamp(6)
  
  // Core EAS fields
  uid             String   @unique @db.VarChar
  attester        String   @db.VarChar
  recipient       String   @db.VarChar
  time            Int // Using time instead of timestamp to mimic AES indexer
  blockNumber     Int
  transactionHash String   @db.VarChar
  schemaId        String   @db.VarChar

  // Prediction market raw data
  data            String   @db.VarChar    
  decodedDataJson String   @db.VarChar @default("")

  // Prediction market schema data
  resolver        String?  @db.VarChar
  conditionId      String?  @db.VarChar
  condition        Condition? @relation(fields: [conditionId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  prediction      String   @db.VarChar
  comment         String?  @db.Text

  // Relation to scores
  attestation_score AttestationScore?

  @@unique([uid], map: "UQ_attestation_uid")
  @@index([attester], map: "IDX_attestation_attester")
  @@index([recipient], map: "IDX_attestation_recipient")
  @@index([time], map: "IDX_attestation_time")
  @@index([resolver], map: "IDX_attestation_resolver")
  @@map("attestation")
}

model AttestationScore {
  id               Int         @id @default(autoincrement())
  createdAt        DateTime    @default(now()) @db.Timestamp(6)

  // Foreign keys and identifiers
  attestationId    Int         @unique
  attestation      Attestation @relation(fields: [attestationId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  attester         String      @db.VarChar
  marketAddress    String?     @db.VarChar
  marketId         String?     @db.VarChar
  questionId       String?     @db.VarChar
  resolver         String?     @db.VarChar

  // Forecast metadata
  madeAt           Int
  used             Boolean     @default(false)

  // Probability and scoring
  probabilityD18   String?     @db.VarChar
  probabilityFloat Float?
  outcome          Int?
  errorSquared     Float?
  scoredAt         DateTime?   @db.Timestamp(6)

  @@index([attester], map: "IDX_attestation_score_attester")
  @@index([marketAddress], map: "IDX_attestation_score_market_address")
  @@index([marketId], map: "IDX_attestation_score_market_id")
  @@index([attester, marketAddress, marketId], map: "IDX_attestation_score_attester_market")
  @@index([attester, marketAddress, marketId, madeAt], map: "IDX_attestation_score_attester_market_madeat")
  @@map("attestation_score")
}

/// Precomputed horizon-weighted error per (attester, market)
model AttesterMarketTwError {
  id            Int      @id @default(autoincrement())
  createdAt     DateTime @default(now()) @db.Timestamp(6)
  attester      String   @db.VarChar
  marketAddress String   @db.VarChar
  marketId      String   @db.VarChar
  twError       Float
  computedAt    DateTime @updatedAt @db.Timestamp(6)

  @@unique([attester, marketAddress, marketId], map: "UQ_attester_market_tw_error")
  @@index([attester], map: "IDX_attester_market_tw_error_attester")
  @@index([marketAddress, marketId], map: "IDX_attester_market_tw_error_market")
  @@map("attester_market_tw_error")
}

/// Chat message history for ephemeral chat websocket
model ChatMessage {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now()) @db.Timestamp(6)
  text      String   @db.Text
  address   String?  @db.VarChar
  timestamp BigInt   @db.BigInt

  @@index([timestamp], map: "IDX_chat_message_timestamp")
  @@index([address], map: "IDX_chat_message_address")
  @@map("chat_message")
}

model Condition {
  id               String          @id @db.VarChar
  createdAt        DateTime        @default(now()) @db.Timestamp(6)
  question         String          @db.VarChar
  shortName        String?         @db.VarChar
  categoryId       Int?
  category         Category?       @relation(fields: [categoryId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  endTime          Int
  public           Boolean         @default(true)
  description      String          @db.Text
  similarMarkets   String[]        @default([])
  tags             String[]        @default([])
  chainId          Int             @default(42161)
  openInterest     String          @default("0") @db.VarChar
  predictionCount  Int             @default(0)
  /// Canonical resolver address for this condition (latest observed wins)
  resolver         String?         @db.VarChar
  
  // Resolution status
  settled          Boolean         @default(false)
  resolvedToYes    Boolean         @default(false)
  nonDecisive      Boolean         @default(false)
  settledAt        Int?
  assertionId      String?         @db.VarChar
  assertionTimestamp Int?

  // Condition group relationship
  conditionGroupId Int?
  conditionGroup   ConditionGroup? @relation(fields: [conditionGroupId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  displayOrder     Int?            // Order within group, null when not in a group

  // Legacy normalized predictions
  predictions    LegacyPrediction[]

  // Attestations referencing this condition
  attestations   Attestation[]

  @@index([categoryId])
  @@index([endTime])
  @@index([conditionGroupId])
  @@index([resolver], map: "IDX_condition_resolver")
  @@index([public, chainId, settled, conditionGroupId], map: "IDX_condition_market_filter")
  // Raw SQL indexes (not representable in Prisma, managed via migration):
  // - IDX_condition_oi_numeric: ("openInterest"::numeric) DESC WHERE public = true
  // - IDX_condition_public_endtime: "endTime" DESC WHERE public = true
  // - IDX_condition_prediction_count: "predictionCount" DESC WHERE public = true
  // Trigger: trg_prediction_count maintains predictionCount on prediction INSERT/DELETE
  @@map("condition")
}

model ConditionGroup {
  id             Int         @id @default(autoincrement())
  createdAt      DateTime    @default(now()) @db.Timestamp(6)
  name           String      @unique @db.VarChar
  categoryId     Int?
  category       Category?   @relation(fields: [categoryId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  similarMarkets String[]    @default([])
  /// @TypeGraphQL.field(name: "conditions")
  condition      Condition[]

  @@index([categoryId])
  @@map("condition_group")
}

model LegacyPrediction {
  id          Int       @id @default(autoincrement())
  createdAt   DateTime  @default(now()) @db.Timestamp(6)

  // The market condition being predicted
  conditionId String
  condition   Condition @relation(fields: [conditionId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  // Exactly one of these should be set; enforced in application logic
  positionId   Int?
  position     LegacyPosition?   @relation(fields: [positionId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  limitOrderId Int?
  limitOrder   LimitOrder?  @relation(fields: [limitOrderId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  // Conceptual prediction data
  outcomeYes Boolean

  // Optional derived / debugging / traceability fields
  chainId Int?

  @@index([conditionId], map: "IDX_prediction_condition")
  @@index([positionId], map: "IDX_prediction_position")
  @@index([limitOrderId], map: "IDX_prediction_limit_order")
  @@unique([positionId, conditionId], map: "UQ_prediction_position_condition")
  @@unique([limitOrderId, conditionId], map: "UQ_prediction_limit_order_condition")
  @@map("prediction")
}

/// Legacy position model (NFT-based, V1)
model LegacyPosition {
  id               Int       @id @default(autoincrement())
  createdAt        DateTime  @default(now()) @db.Timestamp(6)

  // On-chain identifiers
  chainId          Int
  marketAddress    String    @db.VarChar
  predictor        String    @db.VarChar
  counterparty     String    @db.VarChar
  predictorNftTokenId  String    @db.VarChar
  counterpartyNftTokenId  String    @db.VarChar
  totalCollateral  String    @db.VarChar
  predictorCollateral  String?   @db.VarChar
  counterpartyCollateral  String?   @db.VarChar
  refCode          String?   @db.VarChar

  // Status
  status           LegacyPositionStatus @default(active)
  /// True when the predictor's submitted outcomes were correct (previously makerWon)
  predictorWon     Boolean?
  mintedAt         Int
  settledAt        Int?

  // Derived for UI convenience
  endsAt           Int?

  // Normalized predictions
  predictions   LegacyPrediction[]

  @@index([predictor], map: "IDX_position_predictor")
  @@index([counterparty], map: "IDX_position_counterparty")
  @@index([chainId, marketAddress], map: "IDX_position_chain_market")
  @@index([mintedAt], map: "IDX_position_minted_at")
  @@index([settledAt], map: "IDX_position_settled_at")
  @@index([status], map: "IDX_position_status")
  @@map("position")
}

enum LegacyPositionStatus {
  active
  settled
  consolidated

  @@map("PositionStatus")
}


model LimitOrder {
  id                Int       @id @default(autoincrement())
  createdAt         DateTime  @default(now()) @db.Timestamp(6)

  // On-chain identifiers
  chainId           Int
  marketAddress     String    @db.VarChar
  orderId           String    @db.VarChar
  predictor         String    @db.VarChar
  resolver          String    @db.VarChar
  
  // Order details
  predictorCollateral   String    @db.VarChar
  counterpartyCollateral   String    @db.VarChar
  refCode           String?   @db.VarChar
  
  // Status and lifecycle
  status            LimitOrderStatus @default(pending)
  
  // Timestamps
  placedAt          Int
  filledAt          Int?
  cancelledAt       Int?
  
  // Set when order is filled
  counterparty             String?   @db.VarChar
  
  // Transaction hashes for traceability
  placedTxHash      String    @db.VarChar
  filledTxHash      String?   @db.VarChar
  cancelledTxHash   String?   @db.VarChar
  
  // Normalized predictions
  predictions    LegacyPrediction[]

  @@unique([chainId, marketAddress, orderId], map: "UQ_limit_order_chain_market_id")
  @@index([predictor], map: "IDX_limit_order_predictor")
  @@index([chainId, status], map: "IDX_limit_order_chain_status")
  @@index([status], map: "IDX_limit_order_status")
  @@map("limit_order")
}

enum LimitOrderStatus {
  pending
  filled
  cancelled
}

/// Application-level user record, keyed by wallet address,
/// used for referrals and other per-wallet metadata.
model User {
  id           Int      @id @default(autoincrement())
  createdAt    DateTime @default(now()) @db.Timestamp(6)
  updatedAt    DateTime @updatedAt @db.Timestamp(6)

  /// Canonical Ethereum wallet address for this user.
  address      String   @unique(map: "UQ_user_address") @db.VarChar

  /// keccak256(utf8(trimmed_lowercase_code)) stored as 0x-prefixed hex.
  refCodeHash  String?  @unique(map: "UQ_user_ref_code_hash") @db.VarChar

  /// Maximum number of referrals this user's code allows. Default is 0,
  /// so codes are not usable until explicitly configured.
  maxReferrals Int      @default(0)

  referredById Int?
  referredBy   User?   @relation("UserReferrals", fields: [referredById], references: [id])
  referrals    User[]  @relation("UserReferrals")

  referredByCodeId  Int?
  referredByCode    ReferralCode? @relation("AdminCodeClaims", fields: [referredByCodeId], references: [id])

  @@index([address], map: "IDX_user_address")
  @@map("app_user")
}


model ReferralCode {
  id           Int       @id @default(autoincrement())
  createdAt    DateTime  @default(now()) @db.Timestamp(6)
  updatedAt    DateTime  @updatedAt @db.Timestamp(6)


  codeHash     String    @unique(map: "UQ_referral_code_hash") @db.VarChar
  maxClaims    Int
  isActive     Boolean   @default(true)
  expiresAt    Int?
  createdBy    String    @db.VarChar
  creatorType  String    @default("user") @db.VarChar(10)
  claimedBy    User[]    @relation("AdminCodeClaims")
  @@index([codeHash], map: "IDX_referral_code_hash")
  @@index([isActive], map: "IDX_referral_code_active")
  @@index([createdBy], map: "IDX_referral_code_created_by")
  @@map("referral_code")
}

/// Daily snapshot of protocol stats from Vault and PredictionMarket contracts
model ProtocolStatsSnapshot {
  id            Int      @id @default(autoincrement())
  createdAt     DateTime @default(now()) @db.Timestamp(6)

  /// Unix timestamp of the snapshot (UTC midnight, seconds since epoch)
  timestamp     Int
  chainId       Int      @default(5064014)
  vaultAddress  String   @default("") @db.VarChar

  /// Vault balance: wUSDe.balanceOf(vault) only, excludes deployed funds (in wei)
  vaultBalance  String   @db.VarChar

  /// Vault available assets: vault.availableAssets() - excludes pending deposits (in wei)
  vaultAvailableAssets String @default("0") @db.VarChar

  /// Vault deployed: vault.totalDeployed() - funds deployed to escrow (in wei)
  vaultDeployed String   @default("0") @db.VarChar

  /// Escrow balance: wUSDe.balanceOf(predictionMarket) (in wei)
  escrowBalance String   @db.VarChar

  /// Vault PnL metrics
  vaultRealizedPnL      String   @default("0") @db.VarChar  // Total realized PnL from predictions
  vaultAirdropGains     String   @default("0") @db.VarChar  // Unexpected balance increases
  vaultDeposits         String   @default("0") @db.VarChar  // Total user deposits
  vaultWithdrawals      String   @default("0") @db.VarChar  // Total user withdrawals
  vaultPositionsWon     Int      @default(0)
  vaultPositionsLost    Int      @default(0)
  vaultCollateralWon    String   @default("0") @db.VarChar
  vaultCollateralLost   String   @default("0") @db.VarChar

  @@unique([chainId, vaultAddress, timestamp], map: "UQ_protocol_stats_snapshot_chain_vault_timestamp")
  @@index([timestamp], map: "IDX_protocol_stats_snapshot_timestamp")
  @@index([chainId])
  @@map("protocol_stats_snapshot")
}

/// Indexed vault deposit/withdrawal events for accurate PnL tracking
model VaultFlowEvent {
  id              Int      @id @default(autoincrement())
  createdAt       DateTime @default(now()) @db.Timestamp(6)
  chainId         Int
  blockNumber     Int
  transactionHash String   @db.VarChar
  timestamp       Int
  logIndex        Int
  eventType       String   @db.VarChar  // 'deposit' or 'withdrawal'
  user            String   @db.VarChar
  assets          String   @db.VarChar  // Amount in wei
  shares          String   @db.VarChar  // Shares minted/burned

  @@unique([chainId, transactionHash, logIndex])
  @@index([chainId, timestamp])
  @@index([eventType])
  @@map("vault_flow_event")
}

// ───────────────────────────────────────────────
// Prediction Market Models (current system)
// ───────────────────────────────────────────────

enum SettlementResult {
  UNRESOLVED
  PREDICTOR_WINS
  COUNTERPARTY_WINS
  NON_DECISIVE

  @@map("V2SettlementResult")
}

/// Tracks the indexer's last-processed block per chain + contract
model IndexerState {
  id               Int      @id @default(autoincrement())
  createdAt        DateTime @default(now()) @db.Timestamp(6)
  updatedAt        DateTime @updatedAt @db.Timestamp(6)
  chainId          Int
  marketAddress    String   @db.VarChar
  lastIndexedBlock Int
  lastIndexedAt    DateTime @default(now()) @db.Timestamp(6)

  @@unique([chainId, marketAddress])
}

/// A prediction (position) created on-chain via PredictionMarketEscrow
model Prediction {
  id                     Int       @id @default(autoincrement())
  createdAt              DateTime  @default(now()) @db.Timestamp(6)

  predictionId           String    @unique @db.VarChar
  chainId                Int
  marketAddress          String    @db.VarChar
  predictor              String    @db.VarChar
  counterparty           String    @db.VarChar
  predictorCollateral    String    @db.VarChar
  counterpartyCollateral String    @db.VarChar
  onChainCreatedAt       Int
  createTxHash           String    @db.VarChar
  refCode                String?   @db.VarChar

  // Pick configuration FK (nullable for rare RPC-error cases)
  pickConfigId           String?   @db.VarChar
  pickConfiguration      Picks?    @relation(fields: [pickConfigId], references: [id])

  // Settlement
  settled                Boolean   @default(false)
  settledAt              Int?
  settleTxHash           String?   @db.VarChar
  result                 SettlementResult @default(UNRESOLVED)
  predictorClaimable     String?   @db.VarChar
  counterpartyClaimable  String?   @db.VarChar

  // Collateral deposit tracking
  collateralDeposited    String?   @db.VarChar
  collateralDepositedAt  Int?

  // Legacy contract flag
  isLegacy               Boolean   @default(false)

  @@index([chainId, marketAddress], map: "IDX_prediction_chain_market")
  @@index([predictor], map: "IDX_prediction_predictor")
  @@index([counterparty], map: "IDX_prediction_counterparty")
  @@index([settled], map: "IDX_prediction_settled")
  @@index([onChainCreatedAt], map: "IDX_prediction_created_at")
  @@index([settledAt], map: "IDX_prediction_settled_at")
  @@index([pickConfigId], map: "IDX_prediction_pick_config_id")
}

// TODO: Rename Prisma model Picks → PickConfiguration (requires migration with @@map)
/// A pick configuration (group of picks that define a combined position)
model Picks {
  id                           String    @id @db.VarChar
  createdAt                    DateTime  @default(now()) @db.Timestamp(6)

  chainId                      Int
  marketAddress                String    @db.VarChar
  totalPredictorCollateral     String    @default("0") @db.VarChar
  totalCounterpartyCollateral  String    @default("0") @db.VarChar
  claimedPredictorCollateral   String    @default("0") @db.VarChar
  claimedCounterpartyCollateral String   @default("0") @db.VarChar
  resolved                     Boolean   @default(false)
  result                       SettlementResult @default(UNRESOLVED)
  resolvedAt                   Int?
  predictorToken               String?   @db.VarChar
  counterpartyToken            String?   @db.VarChar
  endsAt                       Int?
  fullyRedeemed                Boolean   @default(false)

  // Legacy contract flag
  isLegacy                     Boolean   @default(false)

  picks                        Pick[]
  positionBalances             Position[]
  predictions                  Prediction[]

  @@index([chainId, marketAddress], map: "IDX_pick_config_chain_market")
  @@index([resolved], map: "IDX_pick_config_resolved")
  @@index([fullyRedeemed], map: "IDX_pick_config_fully_redeemed")
}

/// Individual pick within a pick configuration
model Pick {
  id                  Int      @id @default(autoincrement())
  createdAt           DateTime @default(now()) @db.Timestamp(6)

  pickConfigId        String   @db.VarChar
  pickConfiguration   Picks    @relation(fields: [pickConfigId], references: [id], onDelete: Cascade)

  conditionResolver   String   @db.VarChar
  conditionId         String   @db.VarChar
  predictedOutcome    Int

  @@index([pickConfigId], map: "IDX_pick_config_id")
  @@index([conditionId], map: "IDX_pick_condition_id")
}

/// Token balance tracking for positions
model Position {
  id               Int      @id @default(autoincrement())
  createdAt        DateTime @default(now()) @db.Timestamp(6)
  updatedAt        DateTime @updatedAt @db.Timestamp(6)

  chainId          Int
  tokenAddress     String   @db.VarChar
  pickConfigId     String   @db.VarChar
  pickConfiguration Picks   @relation(fields: [pickConfigId], references: [id], onDelete: Cascade)
  isPredictorToken Boolean
  holder           String   @db.VarChar
  balance          String   @db.VarChar

  @@unique([chainId, tokenAddress, holder], map: "UQ_position_balance")
  @@index([holder], map: "IDX_position_balance_holder")
  @@index([pickConfigId], map: "IDX_position_balance_pick_config")
  @@index([tokenAddress], map: "IDX_position_token_address")
}

/// Record of token claims (early exit via redeem)
model Claim {
  id              Int      @id @default(autoincrement())
  createdAt       DateTime @default(now()) @db.Timestamp(6)

  chainId         Int
  marketAddress   String   @db.VarChar
  predictionId    String   @db.VarChar
  holder          String   @db.VarChar
  positionToken   String   @db.VarChar
  tokensBurned    String   @db.VarChar
  collateralPaid  String   @db.VarChar
  redeemedAt      Int
  txHash          String   @db.VarChar
  refCode         String?  @db.VarChar

  @@index([chainId, marketAddress], map: "IDX_claim_chain_market")
  @@index([holder], map: "IDX_claim_holder")
  @@index([predictionId], map: "IDX_claim_prediction")
  @@index([redeemedAt], map: "IDX_claim_redeemed_at")
}

/// Record of position closes (settled exits)
model Close {
  id                       Int      @id @default(autoincrement())
  createdAt                DateTime @default(now()) @db.Timestamp(6)

  chainId                  Int
  marketAddress            String   @db.VarChar
  pickConfigId             String   @db.VarChar
  predictorHolder          String   @db.VarChar
  counterpartyHolder       String   @db.VarChar
  predictorTokensBurned    String   @db.VarChar
  counterpartyTokensBurned String   @db.VarChar
  predictorPayout          String   @db.VarChar
  counterpartyPayout       String   @db.VarChar
  burnedAt                 Int
  txHash                   String   @db.VarChar
  refCode                  String?  @db.VarChar

  @@index([chainId, marketAddress], map: "IDX_close_chain_market")
  @@index([pickConfigId], map: "IDX_close_pick_config")
  @@index([predictorHolder], map: "IDX_close_predictor")
  @@index([counterpartyHolder], map: "IDX_close_counterparty")
  @@index([burnedAt], map: "IDX_close_burned_at")
}

/// Indexer state for SecondaryMarketEscrow contract
model SecondaryIndexerState {
  chainId          Int      @id
  contractAddress  String   @db.VarChar
  lastIndexedBlock Int
  lastIndexedAt    DateTime @default(now()) @db.Timestamp(6)

  @@map("secondary_indexer_state")
}

/// A secondary market trade executed on-chain via SecondaryMarketEscrow
model SecondaryTrade {
  id          Int       @id @default(autoincrement())
  createdAt   DateTime  @default(now()) @db.Timestamp(6)
  chainId     Int
  tradeHash   String    @unique @db.VarChar
  seller      String    @db.VarChar
  buyer       String    @db.VarChar
  token       String    @db.VarChar
  collateral  String    @db.VarChar
  tokenAmount String    @db.VarChar
  price       String    @db.VarChar
  refCode     String?   @db.VarChar
  executedAt  Int
  txHash      String    @db.VarChar
  blockNumber Int

  @@index([chainId], map: "IDX_secondary_trade_chain")
  @@index([seller], map: "IDX_secondary_trade_seller")
  @@index([buyer], map: "IDX_secondary_trade_buyer")
  @@index([token], map: "IDX_secondary_trade_token")
  @@index([executedAt], map: "IDX_secondary_trade_executed_at")
  @@map("secondary_trade")
}

/// Indexed wUSDe (collateral token) Transfer events on Ethereal for historical balance queries
model CollateralTransfer {
  id              Int      @id @default(autoincrement())
  createdAt       DateTime @default(now()) @db.Timestamp(6)
  chainId         Int
  blockNumber     Int
  timestamp       DateTime @db.Timestamp(6)
  transactionHash String   @db.VarChar
  logIndex        Int
  from            String   @db.VarChar
  to              String   @db.VarChar
  value           String   @db.VarChar  // Amount in wei

  @@unique([chainId, transactionHash, logIndex])
  @@index([chainId, from], map: "IDX_collateral_transfer_from")
  @@index([chainId, to], map: "IDX_collateral_transfer_to")
  @@index([chainId, blockNumber], map: "IDX_collateral_transfer_block")
  @@map("collateral_transfer")
}
