{
  "name": "@sapience/api",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "compile": "pnpm lint:fix && pnpm run prisma:generate && tsc",
    "build": "pnpm lint:fix && pnpm run prisma:generate && tsc && npm run sentry:sourcemaps",
    "dev": "pnpm prisma:setup && concurrently \"pnpm run dev:service\" \"pnpm run dev:worker\" \"pnpm run dev:codegen\"",
    "dev:service": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/workers/worker.ts",
    "dev:codegen": "graphql-codegen --config codegen.ts --watch",
    "start": "pnpm run prisma:setup && concurrently \"pnpm run start:service\" \"pnpm run start:worker\"",
    "start:service": "pnpm run prisma:setup && tsx src/server.ts",
    "start:worker": "pnpm run prisma:setup && tsx src/workers/worker.ts",
    "start:reconciler-worker": "pnpm run prisma:setup && tsx src/workers/reconcilerWorker.ts",
    "start:reindex-eas": "tsx src/workers/worker.ts reindexEAS $*",
    "start:reindex-accuracy": "tsx src/workers/worker.ts reindexAccuracy $*",
    "start:backfill-accuracy": "tsx src/workers/worker.ts backfillAccuracy $*",
    "start:compute-stats": "tsx src/workers/worker.ts computeProtocolStats $*",
    "start:backfill-stats": "tsx src/workers/worker.ts backfillProtocolStats $*",
    "start:reindex-condition-settled": "tsx src/workers/worker.ts reindexConditionSettled $*",
    "start:reindex-transfers": "tsx src/workers/worker.ts reindexTransfers $*",
    "start:reindex-collateral-transfers": "tsx src/workers/worker.ts reindexCollateralTransfers $*",
    "pretest": "pnpm --filter @sapience/sdk run build:lib",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:prediction-e2e": "tsx test-prediction-indexer-e2e.ts",
    "test:prediction-mint": "tsx test-prediction-indexer-e2e.ts mint",
    "test:prediction-burn": "tsx test-prediction-indexer-e2e.ts burn",
    "test:prediction-both": "tsx test-prediction-indexer-e2e.ts both",
    "test:prediction-assertion": "tsx test-prediction-indexer-e2e.ts assertion",
    "test:websocket": "tsx test-websocket-connection.ts",
    "test:x402": "tsx src/scripts/testX402Payment.ts",
    "test:rate-limiting": "tsx src/scripts/testRateLimiting.ts",
    "emit-schema": "tsx src/scripts/emitSchema.ts",
    "generate-types": "pnpm run prisma:generate && pnpm run emit-schema && graphql-codegen --config codegen.ts",
    "sentry:sourcemaps": "sentry-cli sourcemaps inject --org foil --project data ./dist && sentry-cli sourcemaps upload --org foil --project data ./dist",
    "lint": "eslint src --quiet",
    "lint:fix": "eslint src --fix --quiet && pnpm format",
    "format": "prettier --write src",
    "prisma:generate": "SKIP_PRISMA_VERSION_CHECK=true prisma generate",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:setup": "prisma migrate deploy && SKIP_PRISMA_VERSION_CHECK=true prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:reset": "prisma migrate reset",
    "prisma:studio": "prisma studio",
    "prisma:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "type-check": "tsc --noEmit",
    "format:check": "prettier --check src"
  },
  "keywords": [],
  "dependencies": {
    "@apollo/server": "5.4.0",
    "@apollo/server-plugin-response-cache": "5.0.0",
    "@as-integrations/express4": "1.1.2",
    "@ethereum-attestation-service/eas-sdk": "2.7.0",
    "@prisma/client": "6.10.1",
    "@sapience/sdk": "workspace:*",
    "@sentry/cli": "2.42.2",
    "@sentry/node": "8.49.0",
    "@x402/core": "2.3.1",
    "@x402/evm": "2.3.1",
    "@x402/express": "2.3.0",
    "class-validator": "0.14.1",
    "concurrently": "8.2.2",
    "cors": "2.8.5",
    "dotenv": "16.4.5",
    "envalid": "8.1.0",
    "express": "4.21.2",
    "express-rate-limit": "7.5.0",
    "graphql": "16.12.0",
    "graphql-depth-limit": "1.1.0",
    "graphql-scalars": "1.24.2",
    "helmet": "8.1.0",
    "http-proxy-middleware": "3.0.3",
    "prettier": "3.3.3",
    "prisma": "6.10.1",
    "reflect-metadata": "0.2.2",
    "tsx": "4.19.2",
    "type-graphql": "2.0.0-rc.2",
    "typegraphql-prisma": "0.28.0",
    "typescript": "5.8.3",
    "viem": "2.47.2",
    "ws": "8.18.3"
  },
  "devDependencies": {
    "@eslint/js": "9.18.0",
    "@graphql-codegen/cli": "5.0.5",
    "@graphql-codegen/typescript": "4.1.6",
    "@graphql-codegen/typescript-operations": "4.6.0",
    "@types/cors": "2.8.17",
    "@types/express": "4.17.21",
    "@types/graphql-depth-limit": "1.1.6",
    "@types/node": "20.17.10",
    "@types/supertest": "6.0.3",
    "@types/ws": "8.18.1",
    "eslint": "9.15.0",
    "eslint-plugin-import": "2.32.0",
    "globals": "15.14.0",
    "supertest": "7.2.2",
    "typescript-eslint": "8.21.0",
    "vitest": "2.1.9"
  },
  "engines": {
    "node": ">=22.x",
    "pnpm": "9.x"
  }
}
