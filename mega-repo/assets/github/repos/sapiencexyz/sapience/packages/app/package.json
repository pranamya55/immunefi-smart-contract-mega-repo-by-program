{
  "name": "@sapience/app",
  "version": "0.1.0",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "NODE_ENV=development next dev --turbo --port 3000",
    "build": "pnpm lint && next build",
    "build:turbo": "turbo run build",
    "postbuild": "next-sitemap --config next-sitemap.config.js",
    "start": "next start",
    "lint": "eslint src --quiet",
    "lint:fix": "eslint src --fix --quiet && pnpm format",
    "type-check": "tsc --noEmit",
    "check:turbo": "npx turbo lint type-check",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "format": "prettier --write src",
    "up-interactive": "pnpm up -i",
    "up-latest": "pnpm up-interactive -L",
    "release": "cross-env HUSKY=0 standard-version",
    "push-release": "git push --follow-tags origin main",
    "prepare": "echo 'Skipping husky install'",
    "format:check": "prettier --check src",
    "build:static": "node scripts/build-static.mjs",
    "pin:ipfs": "node scripts/pin-ipfs.mjs"
  },
  "dependencies": {
    "@hookform/resolvers": "3.9.0",
    "@sapience/sdk": "workspace:*",
    "@sapience/ui": "workspace:*",
    "@sentry/nextjs": "8.49.0",
    "@tanstack/react-query": "5.84.2",
    "@tanstack/react-table": "8.21.2",
    "@tanstack/react-virtual": "3.10.9",
    "@vercel/analytics": "1.4.1",
    "@zerodev/ecdsa-validator": "5.4.9",
    "@zerodev/permissions": "5.6.3",
    "@zerodev/sdk": "5.5.7",
    "abitype": "1.0.8",
    "blo": "2.0.0",
    "clsx": "2.1.1",
    "date-fns": "3.6.0",
    "embla-carousel-auto-scroll": "8.6.0",
    "framer-motion": "12.23.23",
    "graphql": "16.10.0",
    "lucide-react": "0.461.0",
    "next": "15.5.9",
    "next-themes": "0.3.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "7.53.0",
    "react-icons": "4.12.0",
    "react-markdown": "10.1.0",
    "recharts": "2.15.4",
    "remark-breaks": "4.0.0",
    "remark-gfm": "4.0.1",
    "tailwind-merge": "2.5.4",
    "viem": "2.47.2",
    "wagmi": "2.19.5",
    "zod": "3.25.1"
  },
  "devDependencies": {
    "@eslint/js": "9.18.0",
    "@graphql-eslint/eslint-plugin": "4.4.0",
    "@next/eslint-plugin-next": "15.5.9",
    "@playwright/test": "1.55.1",
    "@tanstack/react-query-devtools": "5.84.2",
    "@testing-library/react": "16.3.1",
    "@testing-library/jest-dom": "6.6.3",
    "@types/react": "19.1.8",
    "autoprefixer": "10.4.20",
    "cross-env": "7.0.3",
    "eslint": "9.31.0",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "5.2.0",
    "jsdom": "25.0.1",
    "next-sitemap": "4.2.3",
    "postcss": "8.5.3",
    "prettier": "3.3.3",
    "standard-version": "9.5.0",
    "tailwindcss": "3.4.14",
    "typescript": "5.8.3",
    "typescript-eslint": "8.21.0",
