{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "rootDir": "."
  },
  "include": ["*.ts", "src/**/*.ts", "scripts/**/*.ts", "misc/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
