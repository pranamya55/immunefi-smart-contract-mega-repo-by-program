# Polygon RPC URL (required)
POLYGON_RPC_URL=https://polygon-rpc.com

# Private key for signing transactions (required for --execute mode)
# Must have POL for gas + LayerZero fees (~0.65 POL per settlement)
PRIVATE_KEY=0x...

# Sapience GraphQL API URL (optional, defaults to https://api.sapience.xyz/graphql)
# SAPIENCE_API_URL=https://api.sapience.xyz/graphql

# Chain ID (defaults to 5064014 / Ethereal mainnet)
CHAIN_ID=5064014

# Resolver address (defaults to LZConditionalTokensResolver on Ethereal mainnet)
# Set to ManualConditionResolver for testnet: 0x9938583eA9a6450Cc64502bDcBF76f4EEa2F9560
# RESOLVER_ADDRESS=0xdC1Fa830aD1de01f1EF603749f48bD73384286BE

# Polymarket settle script config (settle-polymarket.ts)
# RESOLVER_ADDRESS=0x9938583eA9a6450Cc64502bDcBF76f4EEa2F9560

ADMIN_PRIVATE_KEY=
LLM_ENABLED=true
OPENROUTER_API_KEY=
NODE_ENV=development