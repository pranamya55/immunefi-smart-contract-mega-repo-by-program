# V2 Testnet Deployment Configuration
# Copy this file to .env and fill in the values

# ===========================================
# PM Network Configuration
# ===========================================
PM_NETWORK_NAME="Ethereal Testnet"
PM_NETWORK_RPC_URL=
PM_NETWORK_DEPLOYER_ADDRESS=
PM_NETWORK_DEPLOYER_PRIVATE_KEY=
PM_NETWORK_LZ_ENDPOINT=
PM_NETWORK_LZ_EID=

# LayerZero DVN Configuration (PM Network)
PM_NETWORK_SEND_LIB=
PM_NETWORK_RECEIVE_LIB=
PM_NETWORK_DVN=
PM_NETWORK_EXECUTOR=

# Contract verification (PM Network)
# Use "blockscout" for Blockscout explorers, "etherscan" for Etherscan-compatible
PM_NETWORK_VERIFIER="blockscout"
PM_NETWORK_ETHERSCAN_API_KEY=
PM_NETWORK_VERIFIER_URL=

# ===========================================
# SM Network Configuration
# ===========================================
SM_NETWORK_NAME="Arbitrum Sepolia"
SM_NETWORK_RPC_URL=
SM_NETWORK_DEPLOYER_ADDRESS=
SM_NETWORK_DEPLOYER_PRIVATE_KEY=
SM_NETWORK_LZ_ENDPOINT=
SM_NETWORK_LZ_EID=

# LayerZero DVN Configuration (SM Network)
SM_NETWORK_SEND_LIB=
SM_NETWORK_RECEIVE_LIB=
SM_NETWORK_DVN=
SM_NETWORK_EXECUTOR=

# Contract verification (SM Network - Arbiscan)
SM_NETWORK_ETHERSCAN_API_KEY=
SM_NETWORK_VERIFIER_URL=

# ===========================================
# Optional Configuration
# ===========================================

# Collateral Token (leave empty to deploy test token with 'collateral' command)
COLLATERAL_TOKEN_ADDRESS=

# Test collateral customization
COLLATERAL_NAME="Test USDe"
COLLATERAL_SYMBOL="tUSDe"
COLLATERAL_INITIAL_SUPPLY="1000000000000000000000000"

# ACK Fee Estimates (for bridge configuration)
PM_ACK_FEE_ESTIMATE=100000000000000
SM_ACK_FEE_ESTIMATE=500000000000000000

# ===========================================
# Testing Configuration (for mint/bridge tests)
# ===========================================
PREDICTOR_PRIVATE_KEY=
COUNTERPARTY_PRIVATE_KEY=
PREDICTOR_WAGER=1000000000000000000
COUNTERPARTY_WAGER=1000000000000000000
BRIDGE_AMOUNT=500000000000000000
