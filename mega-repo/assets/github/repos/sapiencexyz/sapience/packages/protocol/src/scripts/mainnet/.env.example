# V2 Mainnet Deployment Configuration
# Copy this file to .env and fill in the values
#
# WARNING: This is for MAINNET deployment. Double-check all values!

# ===========================================
# PM Network (Ethereal Mainnet) Configuration
# ===========================================
PM_NETWORK_RPC_URL=https://rpc.ethereal.trade
PM_NETWORK_DEPLOYER_ADDRESS=
PM_NETWORK_DEPLOYER_PRIVATE_KEY=
PM_NETWORK_LZ_ENDPOINT=
PM_NETWORK_LZ_EID=

# LayerZero DVN Configuration (PM Network) - 2 DVNs required for mainnet
PM_NETWORK_SEND_LIB=
PM_NETWORK_RECEIVE_LIB=
PM_NETWORK_DVN_1=
PM_NETWORK_DVN_2=
PM_NETWORK_EXECUTOR=

# ===========================================
# SM Network (Arbitrum One) Configuration
# ===========================================
SM_NETWORK_RPC_URL=https://arb1.arbitrum.io/rpc
SM_NETWORK_DEPLOYER_ADDRESS=
SM_NETWORK_DEPLOYER_PRIVATE_KEY=
SM_NETWORK_LZ_ENDPOINT=
SM_NETWORK_LZ_EID=

# LayerZero DVN Configuration (SM Network) - 2 DVNs required for mainnet
SM_NETWORK_SEND_LIB=
SM_NETWORK_RECEIVE_LIB=
SM_NETWORK_DVN_1=
SM_NETWORK_DVN_2=
SM_NETWORK_EXECUTOR=

# Contract verification (Arbiscan)
SM_NETWORK_ETHERSCAN_API_KEY=

# ===========================================
# Collateral Configuration
# ===========================================

# Production collateral token address (wUSDe on Ethereal)
# Canonical address is in @sapience/sdk — see packages/sdk/contracts/addresses.ts
COLLATERAL_TOKEN_ADDRESS=0xB6fC4B1BFF391e5F6b4a3D2C7Bda1FeE3524692D

# Test collateral customization (only used with 'collateral' command)
COLLATERAL_NAME="Test USDe"
COLLATERAL_SYMBOL="tUSDe"
COLLATERAL_INITIAL_SUPPLY="1000000000000000000000000"

# ===========================================
# ACK Fee Estimates
# ===========================================
# PM Network fee (paid in ETH on Arbitrum for ACK back to Ethereal)
PM_ACK_FEE_ESTIMATE=100000000000000

# SM Network fee (paid in USDe on Ethereal for ACK back to Arbitrum)
# Ethereal uses USDe as native token, so this needs to be ~0.5 USDe
SM_ACK_FEE_ESTIMATE=500000000000000000

# ===========================================
# ULN Configuration (optional, defaults shown)
# ===========================================
ULN_CONFIRMATIONS=15
GRACE_PERIOD=0
MAX_MESSAGE_SIZE=10000

# ===========================================
# Testing Configuration (for mint/bridge tests)
# ===========================================
PREDICTOR_PRIVATE_KEY=
COUNTERPARTY_PRIVATE_KEY=
PREDICTOR_WAGER=1000000000000000000
COUNTERPARTY_WAGER=1000000000000000000
BRIDGE_AMOUNT=500000000000000000
