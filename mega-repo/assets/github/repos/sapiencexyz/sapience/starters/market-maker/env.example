# Keys
PRIVATE_KEY=

# Relayer & chain
# Optional: RELAYER_WS_URL (defaults to wss://relayer.sapience.xyz/auction)
# RELAYER_WS_URL=wss://relayer.sapience.xyz/auction

# Chain configuration
# Default: Ethereal (5064014) - native token is USDe, requires wrapping to WUSDe
# CHAIN_ID=5064014

# RPC URL (defaults to https://rpc.ethereal.trade)
# RPC_URL=

# Addresses (defaults resolved from SDK if omitted)
# VERIFYING_CONTRACT=
# COLLATERAL_TOKEN=

# Strategy
# Optional: MIN_MAKER_POSITION_SIZE (defaults to 1)
# MIN_MAKER_POSITION_SIZE=1
# Optional: DEADLINE_SECONDS (defaults to 60)
# DEADLINE_SECONDS=60

# Dynamic pricing
# EDGE_BPS — edge over fair value in basis points (default: 200 = 2%)
# EDGE_BPS=200
# MAX_BID_AMOUNT — max bid in ether (default: 100)
# MAX_BID_AMOUNT=100
# VOLATILITY — annualized vol for Pyth binary option pricing (default: 0.80)
# VOLATILITY=0.80
# MIN_CP_WIN_PROB — skip if counterparty win probability below this (default: 0.05)
# MIN_CP_WIN_PROB=0.05

# Resolver addresses (defaults resolved from SDK for the configured CHAIN_ID)
# PYTH_RESOLVER_ADDRESS=
# CT_RESOLVER_ADDRESS=

# Pyth Lazer feed ID to Hermes price ID mapping (default: BTC, ETH, SOL)
# Format: feedId:hermesId,...
# PYTH_FEED_MAP=2:e62df6c8...,3:ff61491a...,7:ef0d8b6f...
