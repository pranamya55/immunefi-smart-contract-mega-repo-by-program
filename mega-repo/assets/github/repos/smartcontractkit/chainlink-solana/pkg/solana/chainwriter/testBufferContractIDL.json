  "errors": [
    {
      "code": 7000,
      "name": "AlreadyContainsChunk",
      "msg": "The report buffer already contains that chunk"
    },
    {
      "code": 7001,
      "name": "AlreadyInitialized",
      "msg": "The report buffer is already initialized"
    },
    {
      "code": 7002,
      "name": "InvalidLength",
      "msg": "Invalid length for report buffer"
    },
    {
      "code": 7003,
