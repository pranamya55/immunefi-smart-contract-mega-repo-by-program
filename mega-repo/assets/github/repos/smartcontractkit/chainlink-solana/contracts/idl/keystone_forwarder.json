{
  "version": "0.1.0",
  "name": "keystone_forwarder",
  "docs": [
    "Forwarder authenticates chainlink reports and relays them to designated receiver programs."
  ],
  "instructions": [
    {
      "name": "initialize",
      "docs": [
        "Initializes a new Forwarder instance and stores data in its state account"
      ],
      "accounts": [
        {
          "name": "state",
          "isMut": true,
          "isSigner": true
        },
        {
          "name": "owner",
          "isMut": true,
          "isSigner": true
        },
        {
          "name": "systemProgram",
          "isMut": false,
          "isSigner": false
        }
      ],
      "args": []
    },
    {
      "name": "transferOwnership",
      "docs": ["Step 1 of 2-step ownership process: propose a new owner"],
      "accounts": [
        {
          "name": "state",
          "isMut": true,
          "isSigner": false
        },
        {
          "name": "currentOwner",
          "isMut": false,
          "isSigner": true
        }
      ],
      "args": [
        {
          "name": "proposedOwner",
          "type": "publicKey"
        }
      ]
    },
    {
      "name": "acceptOwnership",
      "docs": ["Step 2 of 2-step ownership process: accept ownership"],
      "accounts": [
        {
          "name": "state",
          "isMut": true,
          "isSigner": false
        },
        {
          "name": "proposedOwner",
          "isMut": false,
          "isSigner": true
        }
      ],
      "args": []
    },
    {
      "name": "initOraclesConfig",
      "docs": [
        "Initialize oracles config which describes the set of oracles which",
        "are expected to sign a verified forwarder report. Many oracle config accounts",
        "may exist for a forwarder because more than one DON may be allowed to sign",
        "reports for a forwarder."
      ],
      "accounts": [
        {
          "name": "state",
          "isMut": false,
          "isSigner": false
        },
        {
          "name": "oraclesConfig",
          "isMut": true,
          "isSigner": false
        },
        {
          "name": "owner",
          "isMut": true,
          "isSigner": true
        },
        {
          "name": "systemProgram",
          "isMut": false,
          "isSigner": false
        }
      ],
      "args": [
        {
          "name": "donId",
          "type": "u32"
        },
        {
          "name": "configVersion",
          "type": "u32"
        },
        {
          "name": "f",
          "type": "u8"
        },
        {
          "name": "signerAddresses",
          "type": {
            "vec": {
              "array": ["u8", 20]
            }
          }
        }
      ]
    },
    {
      "name": "updateOraclesConfig",
      "docs": [
        "Updates oracles config under circumstances where the designated",
        "signers or configuration parameters change"
      ],
      "accounts": [
        {
          "name": "state",
          "isMut": false,
          "isSigner": false
        },
        {
          "name": "oraclesConfig",
          "isMut": true,
          "isSigner": false
        },
        {
          "name": "owner",
          "isMut": true,
          "isSigner": true
        }
      ],
      "args": [
        {
          "name": "donId",
          "type": "u32"
        },
        {
          "name": "configVersion",
          "type": "u32"
        },
        {
          "name": "f",
          "type": "u8"
        },
        {
          "name": "signerAddresses",
          "type": {
            "vec": {
              "array": ["u8", 20]
            }
          }
        }
      ]
    },
    {
      "name": "closeOraclesConfig",
      "docs": ["Closes oracle config account"],
      "accounts": [
        {
          "name": "state",
          "isMut": false,
          "isSigner": false
        },
        {
          "name": "oraclesConfig",
          "isMut": true,
          "isSigner": false
        },
        {
          "name": "owner",
          "isMut": true,
          "isSigner": true
        }
      ],
      "args": [
        {
          "name": "donId",
          "type": "u32"
        },
        {
          "name": "configVersion",
          "type": "u32"
        }
      ]
    },
    {
      "name": "report",
      "docs": [
        "The report instruction verifies the report by checking it's ECDSA signatures and ensuring that f + 1 nodes have signed the report.",
        "After verification it will create a PDA to store the execution state if it does not exist.",
        "The ctx.remaining_accounts accounts are passed on to the receiver, alongside the forwarder state account",
        "and forwarder authority signer.",
        "Available space for receiver payload is ~ 297 bytes. However, many factors will affect",
        "this number including adding more accounts in the ctx.remaining_accounts and/or using address",
        "lookup tables. Please refer to ../../docs/forwarder/README.md#L140"
      ],
      "accounts": [
        {
          "name": "state",
          "isMut": false,
          "isSigner": false
        },
        {
          "name": "oraclesConfig",
          "isMut": true,
          "isSigner": false
        },
        {
          "name": "transmitter",
          "isMut": true,
          "isSigner": true
        },
        {
          "name": "forwarderAuthority",
          "isMut": false,
          "isSigner": false
        },
        {
          "name": "executionState",
          "isMut": true,
          "isSigner": false
        },
        {
          "name": "receiverProgram",
          "isMut": false,
          "isSigner": false
        },
        {
          "name": "systemProgram",
          "isMut": false,
          "isSigner": false
        }
      ],
      "args": [
        {
          "name": "data",
          "type": "bytes"
        }
      ]
    }
  ],
  "accounts": [
    {
      "name": "OraclesConfig",
      "docs": [
        "Account which represent a set of oracles expected to sign a forwarder report."
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "configId",
            "type": "u64"
          },
          {
            "name": "f",
            "type": "u8"
          },
          {
            "name": "padding",
            "type": {
              "array": ["u8", 7]
            }
          },
          {
            "name": "signerAddresses",
            "type": {
              "defined": "SignerAddressList"
            }
          }
        ]
      }
    },
    {
      "name": "ForwarderState",
      "docs": ["Account which represents a distinct instance of a forwarder."],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "version",
            "type": "u8"
          },
          {
            "name": "owner",
            "type": "publicKey"
          },
          {
            "name": "proposedOwner",
            "type": "publicKey"
          }
        ]
      }
    },
    {
      "name": "ExecutionState",
      "docs": [
        "Account which stores status of a transmission.",
        "This account will never be closed because it provides persistent proof if a transmission was received on-chain."
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "transmitter",
            "type": "publicKey"
          },
          {
            "name": "transmissionId",
            "type": {
              "array": ["u8", 32]
            }
          },
          {
            "name": "success",
            "type": "bool"
          }
        ]
      }
    }
  ],
  "types": [
    {
      "name": "SignerAddressList",
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "xs",
            "type": {
              "array": [
                {
                  "array": ["u8", 20]
                },
                32
              ]
            }
          },
          {
            "name": "len",
            "type": "u64"
          }
        ]
      }
    },
    {
      "name": "ForwarderError",
      "type": {
        "kind": "enum",
        "variants": [
          {
            "name": "InvalidProposedOwner"
          },
          {
            "name": "ExcessSigners"
          },
          {
            "name": "SignersNotSortedInIncreasingOrder"
          },
          {
            "name": "InvalidReport"
          },
          {
            "name": "InvalidSignatureCount"
          },
          {
            "name": "InvalidSignature"
          },
          {
            "name": "UnauthorizedSigner"
          },
          {
            "name": "DuplicateSignatures"
          },
          {
            "name": "ExecutionAlreadySucceded"
          },
          {
            "name": "FaultToleranceMustBePositive"
          },
          {
            "name": "InsufficientSigners"
          },
          {
            "name": "ForwarderReportExpected"
          },
          {
            "name": "InvalidAccountHash"
          }
        ]
      }
    }
  ],
  "events": [
    {
      "name": "ReportProcessed",
      "fields": [
        {
          "name": "state",
          "type": "publicKey",
          "index": false
        },
        {
          "name": "receiver",
          "type": "publicKey",
          "index": false
        },
        {
          "name": "transmissionId",
          "type": {
            "array": ["u8", 32]
          },
          "index": false
        },
        {
          "name": "result",
          "type": "bool",
          "index": false
        }
      ]
    },
    {
      "name": "ReportInProgress",
      "fields": [
        {
          "name": "state",
          "type": "publicKey",
          "index": false
        },
        {
          "name": "transmissionId",
          "type": {
            "array": ["u8", 32]
          },
          "index": false
        }
      ]
    },
    {
      "name": "ConfigSet",
      "fields": [
        {
          "name": "state",
          "type": "publicKey",
          "index": false
        },
        {
          "name": "oraclesConfig",
          "type": "publicKey",
          "index": false
        },
        {
          "name": "donId",
          "type": "u32",
          "index": false
        },
        {
          "name": "configVersion",
          "type": "u32",
          "index": false
        },
        {
          "name": "f",
          "type": "u8",
          "index": false
        },
        {
          "name": "signers",
          "type": {
            "vec": {
              "array": ["u8", 20]
            }
          },
          "index": false
        }
      ]
    },
    {
      "name": "ForwarderInitialize",
      "fields": [
        {
          "name": "state",
          "type": "publicKey",
          "index": false
        },
        {
          "name": "owner",
          "type": "publicKey",
          "index": false
        }
      ]
    },
    {
      "name": "OwnershipTransfer",
      "fields": [
        {
          "name": "state",
          "type": "publicKey",
          "index": false
        },
        {
          "name": "currentOwner",
          "type": "publicKey",
          "index": false
        },
        {
          "name": "proposedOwner",
          "type": "publicKey",
          "index": false
        }
      ]
    },
    {
      "name": "OwnershipAcceptance",
      "fields": [
        {
          "name": "state",
          "type": "publicKey",
          "index": false
        },
        {
          "name": "previousOwner",
          "type": "publicKey",
          "index": false
        },
        {
          "name": "newOwner",
          "type": "publicKey",
          "index": false
        }
      ]
    }
  ],
  "errors": [
    {
      "code": 6000,
      "name": "Unauthorized",
      "msg": "The signer is unauthorized"
    }
  ]
}
