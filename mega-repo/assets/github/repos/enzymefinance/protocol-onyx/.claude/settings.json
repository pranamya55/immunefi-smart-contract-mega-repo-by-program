{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=$(jq -r '.tool_input.file_path') && [[ \"$FILE\" == *.sol ]] && forge fmt \"$FILE\" || true"
          }
        ]
      }
    ]
  }
}
